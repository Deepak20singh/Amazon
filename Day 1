https://www.geeksforgeeks.org/problems/permutations-of-a-given-string2041/1


class Solution {
    public ArrayList<String> findPermutation(String s) {
        
        String a=new String(s);
        
        Set<String> s1=new HashSet<>();
        
        per(a,"",s1);
        ArrayList<String> a1=new ArrayList<>(s1);
        return a1;
        
        
        
        
    }
    public void per(String input,String ans,Set<String> a){
        if(input.isEmpty()){
            a.add(ans);
            return;
        }
        for(int i=0;i<input.length();i++){
            String remain=input.substring(0,i)+input.substring(i+1);
            per(remain,ans+input.charAt(i),a);
        }
        
        
    }
    
    
}
