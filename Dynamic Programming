import java.util.*;

class Solution{
  public int knapsack(int[] wt, int[] val, int W) {
      int n = wt.length;
      int[][] dp=new int[n][W+1];
      
      for(int[] f:dp){
          Arrays.fill(f,-1);
      }
    
      return solve(wt,val,0,W,dp);
      
  }   
  public int solve(int[] wt,int[] val,int s,int W,int[][] dp){
      if (s == wt.length) return 0;
      if(dp[s][W]!=-1){
          return dp[s][W];
          
      }
     
      int notPick=solve(wt,val,s+1,W,dp);
      int pick=0;
     
      
      if(W>=wt[s]){
       
         pick=val[s]+solve(wt,val,s+1,W-wt[s],dp);
          
      }
      return dp[s][W]=Math.max(pick,notPick);
  }
}

public class Main {
    public static void main(String[] args) {
        Solution obj = new Solution();

        int[] wt = {1, 3, 4, 5};
        int[] val = {1, 4, 5, 7};
        int W = 7;

        int result = obj.knapsack(wt, val, W);
        System.out.println("Maximum Profit: " + result);
    }
}
