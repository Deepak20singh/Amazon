LONGEST VALID PARENTHESE
https://leetcode.com/problems/longest-valid-parentheses/

class Solution {
    public int longestValidParentheses(String s) {
        Stack<Integer> st = new Stack<>();
        st.push(-1);

        int maxLen=0;

        for(int i=0;i<s.length();i++){
            if(s.charAt(i)=='('){
                st.push(i);
            }else{
                st.pop();
                if(st.isEmpty()){
                    st.push(i);
                }else{
                    maxLen=Math.max(maxLen,i-st.peek());
                }


            }
        }
      return maxLen;
      }
}

MIN STACK
https://leetcode.com/problems/min-stack/submissions/1962558472/
class MinStack {
    private Stack<Integer> s;
    private Stack<Integer> minS;
    public MinStack() {
        this.s=new Stack<>();
        this.minS=new Stack<>();
        this.minS.push(Integer.MAX_VALUE);
    }
    
    public void push(int val) {
        this.s.push(val);
        int mini=Math.min(val,this.minS.peek());
        this.minS.push(mini);
    }
    
    public void pop() {
       this.s.pop();
        this.minS.pop();
    }
    
    public int top() {
       return this.s.peek();
    }
    
    public int getMin() {
       return this.minS.peek();
    }
}

