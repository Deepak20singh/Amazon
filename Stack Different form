https://leetcode.com/problems/remove-k-digits/

class Solution {
    public String removeKdigits(String num, int k) {
        Stack<Character> st = new Stack<>();

        for (char c : num.toCharArray()) {
            while (!st.isEmpty() && k > 0 && st.peek() > c) {
                st.pop();
                k--;
            }
            st.push(c);
        }

        // agar k abhi bhi bacha hai
        while (k > 0) {
            st.pop();
            k--;
        }

        // build result
        StringBuilder sb = new StringBuilder();
        for (char c : st) {
            sb.append(c);
        }

        // remove leading zeros
        while (sb.length() > 1 && sb.charAt(0) == '0') {
            sb.deleteCharAt(0);
        }

        return (sb.toString().isEmpty())?"0":sb.toString();
    }
}


DECODE STRING

https://leetcode.com/problems/decode-string/submissions/1962800374/
import java.util.*;

class Solution {
    public String decodeString(String s) {
        Stack<Integer> numStack = new Stack<>();
        Stack<String> strStack = new Stack<>();

        String curr = "";
        int num = 0;

        for (char c : s.toCharArray()) {

            if (Character.isDigit(c)) {
                num = num * 10 + (c - '0');
            }

            else if (c == '[') {
                numStack.push(num);
                strStack.push(curr);

                num = 0;
                curr = "";
            }

            else if (c == ']') {
                int times = numStack.pop();
                String prev = strStack.pop();

                StringBuilder temp = new StringBuilder(prev);
                for (int i = 0; i < times; i++) {
                    temp.append(curr);
                }

                curr = temp.toString();
            }

            else {
                curr += c;
            }
        }

        return curr;
    }
}

SIMPLIFY PATH

https://leetcode.com/problems/simplify-path/

class Solution {
    public String simplifyPath(String path) {
        String[] arr = path.split("/");
        Deque<String> s = new ArrayDeque<>();

        String ans = "/";
        for (String se : arr) {

            if (se.length() == 0 || se.equals(".")) {
                continue;
            }

            if (se.equals("..")) {
                if (!s.isEmpty()) {  
                    s.pop();
                }
            } else {
                s.push(se);  
            }
        }

        while (!s.isEmpty()) {
            String i = s.removeLast();;   
            ans = ans + i;
            if (!s.isEmpty()) ans += "/";  
        }

        return ans;
    }

    // ❌ no longer needed, but keeping minimal change
    public boolean check(String s) {
        boolean ans = true;
        for (char c : s.toCharArray()) {
            if (c != '.') {
                ans = false;
            }
        }
        return ans;
    }
}

